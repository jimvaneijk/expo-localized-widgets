{
    "compilerOptions": {
        "declaration": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "module": "Node16",
        "moduleResolution": "Node16",
        "noUncheckedIndexedAccess": true,
        "rootDir": "src",
        "strict": true,
        "target": "ES2022"
    },
    "include": ["src/**/*.ts"]
}
